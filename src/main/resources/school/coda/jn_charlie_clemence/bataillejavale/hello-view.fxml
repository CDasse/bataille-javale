<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>

<VBox fx:id="scene" alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="school.coda.jn_charlie_clemence.bataillejavale.view.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="welcomeText"/>

    <GridPane fx:id="myGridPane" alignment="CENTER" hgap="1" vgap="1"/>

    <Button text="Generate new grid" onAction="#initializeGridView"/>

    <Label>Width of grid :</Label>
    <Slider fx:id="widthSlider"
            min="8"
            max="15"
            value="10"
            showTickLabels="true"
            showTickMarks="true"
            majorTickUnit="1"
            minorTickCount="0"
            snapToTicks="true" />

    <Label>Height of grid :</Label>
    <Slider fx:id="heightSlider"
            min="8"
            max="15"
            value="10"
            showTickLabels="true"
            showTickMarks="true"
            majorTickUnit="1"
            minorTickCount="0"
            snapToTicks="true" />
</VBox>
